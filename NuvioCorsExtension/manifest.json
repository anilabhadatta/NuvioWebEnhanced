{
  "manifest_version": 3,
  "name": "NuvioWeb CORS Unlocker",
  "version": "1.0",
  "description": "Bypasses CORS restrictions for Torbox and streaming APIs to enable WebCodecs hardware decoding.",
  "permissions": [
    "declarativeNetRequest",
    "declarativeNetRequestFeedback"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "cors_rules",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  }
}
